-server
# NOTE: upstream's jvm.config loads -agentpath:.../libjvmkill.so, but that native
# agent is NOT shipped in the official trino-server tarball (the upstream Docker
# image compiles + injects it separately). Since we build from the tarball on a
# JRE-Alpine base, we omit it — Trino runs fine without the jvmkill agent (it only
# force-kills the JVM on native-thread OOM). Re-add it here if libjvmkill.so is
# ever vendored into bin/.
-XX:InitialRAMPercentage=80
-XX:MaxRAMPercentage=80
-XX:G1HeapRegionSize=32M
-XX:+ExplicitGCInvokesConcurrent
-XX:+HeapDumpOnOutOfMemoryError
-XX:+ExitOnOutOfMemoryError
-XX:-OmitStackTraceInFastThrow
-XX:ReservedCodeCacheSize=256M
-XX:PerMethodRecompilationCutoff=10000
-XX:PerBytecodeRecompilationCutoff=10000
-Djdk.attach.allowAttachSelf=true
-Djdk.nio.maxCachedBufferSize=2000000
-Dfile.encoding=UTF-8
# Allow loading dynamic agent used by JOL
-XX:+EnableDynamicAgentLoading
# https://bugs.openjdk.org/browse/JDK-8327134
-Djava.security.manager=allow
