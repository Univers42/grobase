{
  "version": 1,
  "tenant": { "id": "red-tetris", "name": "Red Tetris", "plan": "enterprise", "owner_user_id": "system:red-tetris" },
  "mounts": [
    {
      "name": "red-tetris-pg",
      "engine": "postgresql",
      "database": "red-tetris",
      "isolation": "shared_rls",
      "read_scoped": true,
      "credentials": { "source": "docker_service", "host": "postgres", "port": 5432 }
    }
  ],
  "roles": [
    {
      "name": "user",
      "policies": [
        {
          "resource_type": "*", "resource_name": "*",
          "actions": ["select", "insert", "update", "delete"],
          "effect": "allow", "priority": 0, "conditions": { "owner_only": true }
        }
      ]
    }
  ],
  "api_keys": [ { "name": "red-tetris-app", "scopes": ["read", "write"] } ],
  "schema": { "postgresql": "infra/config/contracts/red-tetris.schema.sql" },
  "seed": { "script": "scripts/seed/red-tetris-tenant.sh" },
  "frontend_config": {
    "path": "build/red-tetris.env",
    "vars": {
      "PUBLIC_GROBASE_URL": "${KONG_URL}",
      "PUBLIC_BAAS_KEY": "${ANON_KEY}",
      "PUBLIC_API_KEY": "${API_KEY}",
      "PUBLIC_TENANT_ID": "${TENANT_ID}",
      "PUBLIC_PG_DB_ID": "${MOUNT_ID:red-tetris-pg}"
    }
  }
}
