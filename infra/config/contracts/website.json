{
  "version": 1,
  "tenant": { "id": "website", "name": "grobase website portal", "plan": "essential", "owner_user_id": "system:website" },
  "mounts": [
    {
      "name": "website-pg",
      "engine": "postgresql",
      "database": "website",
      "isolation": "shared_rls",
      "read_scoped": true,
      "credentials": { "source": "docker_service", "host": "postgres", "port": 5432 }
    }
  ],
  "roles": [
    {
      "name": "user",
      "policies": [
        {
          "resource_type": "*", "resource_name": "*",
          "actions": ["select", "insert", "update", "delete"],
          "effect": "allow", "priority": 0, "conditions": { "owner_only": true }
        }
      ]
    }
  ],
  "api_keys": [ { "name": "website-app", "scopes": ["read", "write"] } ],
  "schema": { "postgresql": "infra/config/contracts/website.schema.sql" },
  "frontend_config": {
    "path": "build/website.env",
    "vars": {
      "PUBLIC_GROBASE_URL": "${KONG_URL}",
      "PUBLIC_BAAS_KEY": "${ANON_KEY}",
      "PUBLIC_API_KEY": "${API_KEY}",
      "PUBLIC_TENANT_ID": "${TENANT_ID}",
      "PUBLIC_DB_ID": "${MOUNT_ID:website-pg}"
    }
  }
}
