### Python ###
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
# but track the dart SDK's generated client (the Python `lib/` rule is too broad;
# sdks/dart/lib is committed generated code, like the python/swift/kotlin siblings)
!sdks/dart/lib/
!sdks/dart/lib/**
# and track scripts/lib (shared sourced helpers: service-auth.sh, lib-*.sh/.mjs);
# the broad `lib/` rule was swallowing the provisioner's service-auth dependency,
# breaking provision-contract.sh + bench/live-tenant scripts in every fresh clone.
!scripts/lib/
!scripts/lib/**
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

