#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

### Node ###
# Logs
logs
# never ignore source-tree logs modules (e.g. vite-gourmand DevBoard features/logs)
!**/src/**/logs/
!**/src/**/logs/**
!src/apps/log-service/src/logs/
!src/apps/log-service/src/logs/**
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock
observatory.log
# Generated TLS material at the repo root (regenerated by scripts/certs/…). The
# trailing-slash-only form would also swallow scripts/certs/ (the cert SCRIPTS CI
# needs), so un-ignore that dir and re-ignore only its generated key/cert output.
certs/
!scripts/certs/
scripts/certs/*.pem
scripts/certs/*.key
scripts/certs/*.srl
scripts/certs/*-openssl.cnf

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

