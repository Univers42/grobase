# End of https://www.toptal.com/developers/gitignore/api/python,go,visualstudiocode,dotenv,node

# Allow service source lib/ directories (overrides Python lib/ rule above)
!docker/services/*/src/lib/
!docker/services/*/src/lib/**

# Local development TLS certificates generated for track-binocle Astro HTTPS.
certs/*
!certs/.gitkeep

# Migration debris: orphan embedded git repo (gitlink) left by the monorepo
# extraction. De-tracked from the index; kept ignored so it can't be re-added.
/grobase/

# Vendored dev/analysis tool (own .git) — Egonex "Understand Anything" plugin used
# to generate the architecture knowledge graph. Local tooling, NOT product code:
# ignored so it can't be re-added as an orphan gitlink (same hazard as /grobase/).
# Update in place with: git -C vendor/Understand-Anything pull
/vendor/Understand-Anything/

# Other vendored side-projects with their own .git (MovieVerse, the devil's-advocate
# tool) — same orphan-gitlink hazard: ignored so `git add -A` can't embed them as
# broken gitlinks in this repo. They are independent clones, not product code.
/vendor/MovieVerse/
/vendor/claude-deal-with-the-devil/

# vault42 — a SEPARATE product repo (own .git → git@github.com:Univers42/vault42.git),
# developed in-tree here for convenience but committed/pushed only from its own remote
# (gitflow). Ignored so grobase never embeds it as an orphan gitlink. See vault42/DECISIONS.md.
/vendor/vault42/

# Knowledge-graph output produced by the tool. Ignored to keep the repo clean —
# it is fully reproducible from vendor/Understand-Anything (the .ua-*.mjs scripts).
# NOTE: .understand-anything/knowledge-graph.json IS commit-safe if you want to
# share the graph with teammates (see the tool README; use git-lfs above ~10 MB).
.understand-anything/

# ── Generated outputs — NEVER commit (a stray trivy.db hit GitHub's 100 MB wall) ──
# Security scans (trivy fs/image + its 1 GB vuln-DB cache, semgrep, trufflehog,
# npm-audit), test reports (edge/postman HTML+JSON, JUnit XML), and bench/footprint
# JSON are all reproducible by `make tests` / `make bench-*`. Force-add a single
# bench artifact as evidence with `git add -f artifacts/bench/<file>` if needed.
/artifacts/

# ── Compiled Go control-plane binaries — build outputs of cmd/* (~98 MB total). ──
# The toolchain builds these in Docker (`make go-control-plane-build`); never track.
/src/control-plane/adapter-registry
/src/control-plane/function-scheduler
/src/control-plane/orchestrator
/src/control-plane/scale-seed
/src/control-plane/tenant-control
/src/control-plane/webhook-dispatcher

# ── Per-tenant / per-app provisioning state (secrets: api keys, JWT, DSNs) — NEVER track. ──
# Emitted by scripts/seed/*-tenant.sh; sourced by re-runs + the verify gates. Use GLOBS so
# new apps are covered automatically (the old explicit list missed agency/savanna/surfind/…).
*-tenant.env
*-baas.env
*.services.env
.services.env
# cloud overlay carries a real STRIPE_API_KEY — never track (flags.env.example is the template).
infra/config/cloud/flags.env.cloud

# Emitted frontend config carries the app API key — never track (glob covers every app).
**/public/baas-config.js
**/baas-config.js
# Generated audit reports embed live keys/JWTs from the run — never track.
wiki/reports/edge-report.html
wiki/reports/postman-offers-report.html

# local 42ctl CLI state (config + keystore) for the `make ctl` image wrapper
.42ctl/

# Accidental gitlinks (no .gitmodules); local vendored content only.
vendor/scripts/
vendor/twenty/
