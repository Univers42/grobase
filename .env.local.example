# ─────────────────────────────────────────────────────────────────────────────
# .env.local.example — OPTIONAL external secrets + per-developer overrides.
#
# Copy to `.env.local` (gitignored) and fill ONLY what you need. `make env`
# appends this LAST, so anything here overrides config.env and .env.secrets.
#
#   cp .env.local.example .env.local
#
# Each key below is OPTIONAL — required ONLY when you turn its feature on. Leave
# the rest blank; the stack runs fully local (mailpit, no OAuth) without them.
# ─────────────────────────────────────────────────────────────────────────────

# ── OAuth providers — set the pair AND flip the matching toggle in config.env ──
# GOOGLE_OAUTH_ENABLED=true   (in config.env)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GITHUB_OAUTH_ENABLED=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# FORTYTWO_OAUTH_ENABLED=true
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=

# ── Email: a real SMTP provider (leave blank to keep local mailpit) ──
# Also point SMTP_HOST/SMTP_PORT/SMTP_SECURE in config.env at the provider.
SMTP_USER=
SMTP_PASS=

# ── AI service: LLM provider key (required only if you use the AI service) ──
LLM_API_KEY=

# ── GDPR webhooks (required only if you wire external deletion/export sinks) ──
GDPR_DELETION_WEBHOOK_URL=
GDPR_EXPORT_WEBHOOK_URL=

# ── Tooling: SonarCloud scan token (for `make sonar-scan`; personal) ──
SONAR_TOKEN=

# ── Per-developer overrides — any config.env key can be overridden here ──
# e.g. WAF_HTTPS_PORT=9443
