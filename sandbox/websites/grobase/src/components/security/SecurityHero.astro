---
// SECURITY HERO — premium-minimal & cinematic. Deep dark, generous negative
// space, the least information possible: a liquid-glass kicker pill, a short
// headline with ONE serif-italic accent word, one restrained lede, one CTA.
//
// The visual is the LOCAL dashboard-mock.svg (CSP img-src 'self') shown with
// mix-blend luminosity + a bottom gradient fade + a gentle CSS scroll-driven
// parallax (.parallax, from _premium.scss). No autoplay video, no external asset.
import Icon from '../ui/Icon.astro';
---

<section class="gb-section gb-sec-hero" aria-labelledby="sec-hero-title">
	{/* a single restrained background word — far quieter than the maximalist pages */}
	<p class="bgword bgword--right gb-sec-hero__bgword" aria-hidden="true">TRUST</p>

	<div class="gb-container gb-sec-hero__inner">
		<p class="gb-kicker liquid-glass gb-sec-hero__pill accent-2">
			<Icon name="shield" size={16} /> Security posture
		</p>
		<h1 id="sec-hero-title" class="gb-sec-hero__title">
			Security that is <em class="serif-italic">measured</em>, not marketed.
		</h1>
		<p class="gb-lede gb-sec-hero__lede">
			Vault-held secrets, a policy decision point on every call, owner-scoping per request,
			and one hardened public listener. Below is exactly how Grobase is defended — and,
			honestly, what we do not yet claim.
		</p>
		<div class="gb-sec-hero__ctas">
			<a class="gb-btn gb-btn--primary" href="#controls">See the controls</a>
			<a class="gb-btn gb-btn--ghost" href="#disclosure">Report an issue</a>
		</div>
	</div>

	{/* cinematic visual: local SVG, luminosity blend, bottom fade, scroll parallax */}
	<div class="gb-sec-hero__visual parallax parallax--slow" aria-hidden="true">
		<img
			class="gb-sec-hero__mock blend-luminosity"
			src="/img/dashboard-mock.svg"
			alt=""
			width="1280"
			height="720"
			loading="eager"
			decoding="async"
		/>
		<span class="premium-fade-bottom"></span>
	</div>
</section>
