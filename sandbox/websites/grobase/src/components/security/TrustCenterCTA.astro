---
// TRUST CENTER CTA — the closing action band. Three honest doors: the trust
// center, the DPA, and a private vulnerability report. Hrefs are passed in so the
// page owns the destinations (the report link is a mailto:, allowed under CSP — no
// external http(s) egress). Glass surface, class-driven (no inline style).
import Icon from '../ui/Icon.astro';

type Props = {
	trustHref: string;
	dpaHref: string;
	reportHref: string;
};
const { trustHref, dpaHref, reportHref } = Astro.props;

// External destinations open in a new tab; mailto: + in-page anchors stay put.
const isExternal = (href: string) => /^https?:\/\//.test(href);
---

<div class="gb-sec-cta liquid-glass" data-rise>
	<div class="gb-sec-cta__copy">
		<p class="gb-sec-cta__eyebrow accent-2">
			<Icon name="shield" size={16} /> Trust, on request
		</p>
		<p class="gb-sec-cta__lead">
			Need the paperwork? Our evidence, cross-walks and a DPA are available — some under NDA. Found
			a flaw? Tell us privately and we will work it with you in good faith.
		</p>
	</div>
	<div class="gb-sec-cta__actions">
		<a
			class="gb-btn gb-btn--primary"
			href={trustHref}
			target={isExternal(trustHref) ? '_blank' : undefined}
			rel={isExternal(trustHref) ? 'noopener noreferrer' : undefined}
		>
			<Icon name="book-open" size={18} /> Trust center
		</a>
		<a
			class="gb-btn gb-btn--ghost"
			href={dpaHref}
			target={isExternal(dpaHref) ? '_blank' : undefined}
			rel={isExternal(dpaHref) ? 'noopener noreferrer' : undefined}
		>
			<Icon name="file-text" size={18} /> Request a DPA
		</a>
		<a class="gb-btn gb-btn--ghost" href={reportHref}>
			<Icon name="mail" size={18} /> Report a vulnerability
		</a>
	</div>
</div>
