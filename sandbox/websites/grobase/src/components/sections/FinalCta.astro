---
import { SITE } from '../../data/site';
import Icon from '../ui/Icon.astro';
---

<section class="gb-section gb-cta gb-section--patterned gb-section--mesh" aria-labelledby="cta-title">
	{/* ── Giant background word, bleeding off-edge (aria-hidden, zero-CLS) ── */}
	<p class="bgword bgword--bottom" aria-hidden="true">SHIP IT</p>

	{/* ── Floating decorative shapes — rotated accents, animated, aria-hidden ── */}
	<div class="gb-cta__decor" aria-hidden="true">
		<span class="floater floater--lg floater--ring accent-1 animate-float"></span>
		<span class="floater floater--tr accent-2 animate-float-reverse"></span>
		<span class="floater floater--sm floater--square accent-3 tilt-2 animate-float"></span>
		<span class="floater floater--ml floater--diamond accent-4 animate-spin-slow"></span>
		<span class="floater floater--mr accent-5 animate-float-reverse"></span>
		<span class="floater floater--bl floater--square accent-2 tilt-n2 animate-float"></span>
		<span class="floater floater--c1 floater--sm accent-3 animate-float-reverse"></span>
		<span class="floater floater--c2 floater--ring accent-1 animate-spin-slow"></span>
		<span class="gb-cta__emoji gb-cta__emoji--1 animate-wiggle"><Icon name="rocket" size={40} class="accent-1" /></span>
		<span class="gb-cta__emoji gb-cta__emoji--2 animate-bounce-subtle"><Icon name="zap" size={40} class="accent-3" /></span>
		<span class="gb-cta__emoji gb-cta__emoji--3 animate-bounce-subtle"><Icon name="sparkle" size={40} class="accent-2" /></span>
		<span class="gb-cta__emoji gb-cta__emoji--4 animate-wiggle"><Icon name="star" size={40} class="accent-4" /></span>
	</div>

	<div class="gb-container gb-cta-final accent-1">
		<p class="gb-kicker"><span aria-hidden="true"><Icon name="star" size={14} /></span> Ready when you are</p>
		<h2 id="cta-title" class="gradient-text">Build the backend your project actually needs.</h2>
		<p class="gb-lede">
			A weekend project on a 5 MB binary, or thousands of customers on one stack — it's the same
			code and the same simple API. The numbers are public, and the upgrade path is real.
		</p>
		<div class="gb-hero__ctas">
			<a class="gb-btn gb-btn--primary is-pulsing" href="/pricing/">Start free on Nano</a>
			<a class="gb-btn gb-btn--ghost" href={SITE.repoUrl} rel="noopener">Explore the source</a>
		</div>
	</div>
</section>
