---
// ── HeroScene — a cinematic, looping CYBERPUNK NIGHT (pure SVG + CSS + a tiny
// JS animator). A lone figure rests on a neon hilltop swinging one leg, watching
// a synthwave moon through atmospheric haze, god-rays, drifting fog and a
// moonlight reflection. All-code → keeps the strict CSP (no external media), the
// LH-100 budget and the licence clean.
//
// CSP/icon-safety: inline SVG, NO xmlns, NO <script>, NO external href/src, NO
// SMIL — only geometry, internal url(#…) refs, gradients/filters. Motion is driven
// by src/scripts/hero/scene.ts via setAttribute (cross-browser, Firefox-safe) +
// CSS opacity for star twinkle. Decorative → aria-hidden. Reduced-motion → calm
// static night (the JS rests; the CSS twinkle is gated).
//
// Pixel-art layer (original sprites, CSP-clean): distant traffic on the city
// highway + a mouse and a person walking the foreground — all moved/frame-swapped
// by scene.ts. See src/data/pixel-sprites.ts + PixelSprite.astro.
import PixelSprite from './PixelSprite.astro';
import { MOUSE_A, MOUSE_B, MOUSE_PAL, PERSON_A, PERSON_B, PERSON_PAL, CAR, CAR_PALETTES } from '../../data/pixel-sprites';

function mulberry32(a: number) {
	return function () {
		a |= 0;
		a = (a + 0x6d2b79f5) | 0;
		let t = Math.imul(a ^ (a >>> 15), 1 | a);
		t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
		return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
	};
}
const rand = mulberry32(42);
// stars cover a band WIDER than the viewport so the slow celestial rotation
// (scene.ts spins this whole group around a pole, like the night sky turning)
// never reveals a hard edge. A handful are "hero" stars (bigger, with a glow).
const stars = Array.from({ length: 180 }, (_, i) => {
	const r = +(0.4 + rand() * 1.9).toFixed(2);
	return { x: Math.round(-360 + rand() * 2160), y: Math.round(-360 + rand() * 1000), r, b: i % 5, hero: r > 1.95 };
});
// a soft diagonal Milky-Way cluster of faint dust stars
const dust = Array.from({ length: 90 }, () => {
	const t = rand();
	const x = Math.round(140 + t * 1200 + (rand() - 0.5) * 90);
	const y = Math.round(60 + t * 360 + (rand() - 0.5) * 70);
	return { x, y, r: +(0.3 + rand() * 0.9).toFixed(2) };
});
// god-ray angles (degrees) radiating from the moon
const rays = [-46, -32, -18, -4, 10, 24, 40];
---

<div class="gb-scene" aria-hidden="true">
	<svg class="gb-scene__svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" fill="none" role="presentation">
		<defs>
			<linearGradient id="gb-sky" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#050210" />
				<stop offset="0.34" stop-color="#0f0826" />
				<stop offset="0.58" stop-color="#291146" />
				<stop offset="0.76" stop-color="#5e1a52" />
				<stop offset="0.88" stop-color="#9a2a5e" />
				<stop offset="1" stop-color="#2a1240" />
			</linearGradient>
			<radialGradient id="gb-moonglow" cx="0.5" cy="0.5" r="0.5">
				<stop offset="0" stop-color="#ff5cf6" stop-opacity="0.5" />
				<stop offset="0.4" stop-color="#9a3bff" stop-opacity="0.26" />
				<stop offset="1" stop-color="#9a3bff" stop-opacity="0" />
			</radialGradient>
			<radialGradient id="gb-mooncore" cx="0.5" cy="0.5" r="0.5">
				<stop offset="0" stop-color="#fff0fb" stop-opacity="0.85" />
				<stop offset="1" stop-color="#fff0fb" stop-opacity="0" />
			</radialGradient>
			<linearGradient id="gb-moon" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#fff6fc" />
				<stop offset="0.5" stop-color="#ffd9f4" />
				<stop offset="1" stop-color="#ff8fd6" />
			</linearGradient>
			<linearGradient id="gb-ray" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#ffd9f4" stop-opacity="0.22" />
				<stop offset="1" stop-color="#ffd9f4" stop-opacity="0" />
			</linearGradient>
			<linearGradient id="gb-reflect" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#ffc8ee" stop-opacity="0.5" />
				<stop offset="1" stop-color="#ffc8ee" stop-opacity="0" />
			</linearGradient>
			<linearGradient id="gb-haze" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#ff3aa6" stop-opacity="0" />
				<stop offset="0.5" stop-color="#ff3aa6" stop-opacity="0.28" />
				<stop offset="1" stop-color="#2a1240" stop-opacity="0" />
			</linearGradient>
			<linearGradient id="gb-milky" x1="0" y1="0" x2="1" y2="1">
				<stop offset="0" stop-color="#b9a8ff" stop-opacity="0" />
				<stop offset="0.5" stop-color="#b9a8ff" stop-opacity="0.12" />
				<stop offset="1" stop-color="#b9a8ff" stop-opacity="0" />
			</linearGradient>
			<linearGradient id="gb-hill-back" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#492066" />
				<stop offset="1" stop-color="#311652" />
			</linearGradient>
			<linearGradient id="gb-hill-mid" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#26113f" />
				<stop offset="1" stop-color="#190a2b" />
			</linearGradient>
			<linearGradient id="gb-hill-front" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#0c0518" />
				<stop offset="1" stop-color="#06030f" />
			</linearGradient>
			<linearGradient id="gb-fig" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0" stop-color="#1a1338" />
				<stop offset="1" stop-color="#06030f" />
			</linearGradient>
			<radialGradient id="gb-vignette" cx="0.5" cy="0.4" r="0.75">
				<stop offset="0" stop-color="#05030f" stop-opacity="0" />
				<stop offset="0.7" stop-color="#05030f" stop-opacity="0" />
				<stop offset="1" stop-color="#05030f" stop-opacity="0.6" />
			</radialGradient>
			<filter id="gb-glow" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="9" /></filter>
			<filter id="gb-glow-sm" x="-80%" y="-80%" width="260%" height="260%"><feGaussianBlur stdDeviation="3" /></filter>
			<filter id="gb-fog" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="22" /></filter>
		</defs>

		<!-- sky -->
		<rect x="0" y="0" width="1440" height="900" fill="url(#gb-sky)" />

		<!-- Milky-Way dust band -->
		<g class="gb-scene__milky">
			<rect x="-200" y="-120" width="2000" height="280" fill="url(#gb-milky)" transform="rotate(18 720 220)" />
			<g fill="#cdbcff" fill-opacity="0.5">
				{dust.map((d) => <circle cx={d.x} cy={d.y} r={d.r} />)}
			</g>
		</g>

		<!-- moon glow halos -->
		<circle cx="1050" cy="262" r="300" fill="url(#gb-moonglow)" />
		<circle cx="1050" cy="262" r="190" fill="url(#gb-mooncore)" />

		<!-- volumetric god-rays from the moon (additive light via CSS screen blend) -->
		<g class="gb-scene__rays">
			{rays.map((deg) => (
				<polygon points="1050,262 1018,1180 1082,1180" fill="url(#gb-ray)" transform={`rotate(${deg} 1050 262)`} />
			))}
		</g>

		<!-- stars (twinkle via CSS opacity) -->
		<g class="gb-scene__stars" fill="#ffffff">
			{stars.map((s) => (
				<circle class={`gb-star gb-star--${s.b}`} cx={s.x} cy={s.y} r={s.r} filter={s.hero ? 'url(#gb-glow-sm)' : undefined} />
			))}
		</g>

		<!-- moon: disc + synthwave scan-cuts + neon rim -->
		<circle class="gb-scene__moon" cx="1050" cy="262" r="118" fill="url(#gb-moon)" />
		<g fill="#0f0826">
			<rect x="932" y="298" width="236" height="6" rx="3" />
			<rect x="940" y="316" width="220" height="8" rx="4" />
			<rect x="952" y="336" width="196" height="10" rx="5" />
			<rect x="968" y="358" width="164" height="12" rx="6" />
		</g>
		<g class="gb-scene__moon-rim" opacity="0.6">
			<circle cx="1050" cy="262" r="118" fill="none" stroke="#00f5d4" stroke-width="2" stroke-opacity="0.6" />
		</g>

		<!-- a slow shooting star (JS-driven) -->
		<g class="gb-scene__shoot" opacity="0">
			<line x1="120" y1="120" x2="190" y2="150" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" />
			<circle cx="190" cy="150" r="2.6" fill="#ffffff" />
		</g>

		<!-- horizon haze glow -->
		<rect x="0" y="540" width="1440" height="140" fill="url(#gb-haze)" />
		<rect x="0" y="600" width="1440" height="2" fill="#ff3af2" fill-opacity="0.6" filter="url(#gb-glow-sm)" />

		<!-- distant cyberpunk skyline (hazy, low contrast → atmospheric depth) -->
		<g class="gb-scene__city" fill="#321a52" fill-opacity="0.7">
			<rect x="150" y="540" width="34" height="62" /><rect x="196" y="512" width="26" height="90" />
			<rect x="232" y="556" width="40" height="46" /><rect x="286" y="498" width="22" height="104" />
			<rect x="320" y="544" width="30" height="58" /><rect x="690" y="548" width="30" height="54" />
			<rect x="732" y="520" width="24" height="82" /><rect x="766" y="556" width="36" height="46" />
			<rect x="1180" y="556" width="30" height="46" /><rect x="1222" y="528" width="22" height="74" />
		</g>
		<g class="gb-scene__windows" fill="#00f5d4" fill-opacity="0.7">
			<rect x="204" y="524" width="3" height="3" /><rect x="212" y="548" width="3" height="3" />
			<rect x="294" y="512" width="3" height="3" /><rect x="300" y="540" width="3" height="3" />
			<rect x="740" y="532" width="3" height="3" /><rect x="1230" y="540" width="3" height="3" />
		</g>

		<!-- layered neon hills, back → front, with haze between for aerial depth -->
		<path class="gb-scene__hill gb-scene__hill--back" fill="url(#gb-hill-back)"
			d="M-40 640 C 240 560, 460 596, 720 568 C 1000 540, 1240 612, 1480 576 L1480 900 L-40 900 Z" />
		<rect x="0" y="612" width="1440" height="80" fill="url(#gb-haze)" opacity="0.5" />
		<path class="gb-scene__hill gb-scene__hill--mid" fill="url(#gb-hill-mid)"
			d="M-40 712 C 300 656, 560 700, 880 676 C 1120 658, 1320 706, 1480 686 L1480 900 L-40 900 Z" />
		<rect x="0" y="690" width="1440" height="64" fill="url(#gb-haze)" opacity="0.35" />

		<!-- moonlight reflection on the slope below the moon -->
		<rect class="gb-scene__reflect" x="1018" y="600" width="64" height="240" fill="url(#gb-reflect)" filter="url(#gb-glow)" />

		<path class="gb-scene__hill gb-scene__hill--front" fill="url(#gb-hill-front)"
			d="M-40 800 C 260 752, 520 786, 760 772 C 1040 756, 1280 800, 1480 782 L1480 900 L-40 900 Z" />

		<!-- drifting fog wisps low over the hills (JS-driven) -->
		<g class="gb-scene__fog" fill="#b487ff" fill-opacity="0.10" filter="url(#gb-fog)">
			<ellipse cx="360" cy="724" rx="280" ry="34" />
			<ellipse cx="980" cy="748" rx="340" ry="38" />
		</g>

		<!-- the figure: a shaded seated silhouette on the front hill below the moon,
		     leaning back on a hand, gazing up, with the near leg dangling + swinging. -->
		<g class="gb-scene__figure" transform="translate(992 742) scale(1.5)">
			<ellipse cx="6" cy="6" rx="42" ry="8" fill="#000008" fill-opacity="0.5" filter="url(#gb-glow-sm)" />
			<circle cx="-6" cy="-30" r="56" fill="#ff3af2" fill-opacity="0.20" filter="url(#gb-glow)" />
			<g stroke-linecap="round" stroke-linejoin="round">
				<path d="M-13 -33 L-26 -16 L-38 3" fill="none" stroke="url(#gb-fig)" stroke-width="6.5" />
				<path d="M2 -3 L27 -7" fill="none" stroke="#130d2c" stroke-width="8.5" />
				<path d="M27 -7 L29 33" fill="none" stroke="#130d2c" stroke-width="7.5" />
				<path d="M3 -1 C -7 -13, -14 -24, -16 -35 C -10 -38, -3 -34, 0 -27 C 4 -16, 9 -7, 13 -1 Z" fill="url(#gb-fig)" />
				<path d="M-13 -33 L-19 -43" fill="none" stroke="url(#gb-fig)" stroke-width="6.5" />
				<ellipse cx="-23" cy="-49" rx="7.6" ry="9.2" fill="url(#gb-fig)" transform="rotate(-15 -23 -49)" />
				<path d="M-30 -53 C -33 -49, -32 -43, -28 -41 L-24 -44 Z" fill="#06030f" />
				<path d="M-30 -55 A 9.5 9.5 0 0 1 -15 -53" fill="none" stroke="#00f5d4" stroke-width="2" stroke-opacity="0.9" filter="url(#gb-glow-sm)" />
				<circle cx="-15" cy="-48" r="2.2" fill="#00f5d4" filter="url(#gb-glow-sm)" />
				<path d="M5 -3 L30 -6" fill="none" stroke="url(#gb-fig)" stroke-width="10" />
				<g class="gb-scene__leg">
					<path d="M30 -6 L34 34" fill="none" stroke="#100a26" stroke-width="9" />
					<path d="M34 34 L45 37" fill="none" stroke="#100a26" stroke-width="6.5" />
					<path d="M28 -5 L32 33" fill="none" stroke="#00f5d4" stroke-width="2.3" stroke-opacity="0.85" filter="url(#gb-glow-sm)" />
					<circle cx="44.5" cy="36.5" r="2" fill="#00f5d4" filter="url(#gb-glow-sm)" />
				</g>
				<!-- rim-lights: cyan moon-facing edge, faint magenta back edge -->
				<path d="M-1 -28 C 3 -17, 8 -8, 12 -2" fill="none" stroke="#00f5d4" stroke-width="1.7" stroke-opacity="0.75" />
				<path d="M-15 -36 C -13 -28, -10 -20, -6 -14" fill="none" stroke="#ff5cf6" stroke-width="1.4" stroke-opacity="0.5" />
			</g>
		</g>

		<!-- foreground ground bloom -->
		<rect x="0" y="792" width="1440" height="108" fill="#7b2fff" fill-opacity="0.10" />

		<!-- ── foreground STREET + neon lighting + pixel-art life (JS-driven) ──
		     Kept on the front-hill crest (~y744-776) so it stays within the visible
		     viewBox — the very bottom of the scene is cropped on short viewports. -->
		<rect x="0" y="746" width="1440" height="42" fill="#130b24" />
		<rect x="0" y="744" width="1440" height="2.5" fill="#00f5d4" fill-opacity="0.65" />
		<rect x="0" y="748" width="1440" height="7" fill="#211238" opacity="0.6" />
		<line x1="0" y1="768" x2="1440" y2="768" stroke="#ff3af2" stroke-width="2.5" stroke-dasharray="32 26" stroke-opacity="0.6" />

		<!-- streetlamps cast neon pools so the characters are lit + readable -->
		<g class="gb-scene__lamps">
			<g transform="translate(150 0)"><ellipse cx="0" cy="764" rx="140" ry="34" fill="#00f5d4" fill-opacity="0.12" filter="url(#gb-glow)" /><rect x="-2" y="710" width="4" height="40" fill="#2a1c3e" /><circle cx="0" cy="710" r="5" fill="#00f5d4" filter="url(#gb-glow-sm)" /></g>
			<g transform="translate(560 0)"><ellipse cx="0" cy="764" rx="140" ry="34" fill="#ff3af2" fill-opacity="0.12" filter="url(#gb-glow)" /><rect x="-2" y="710" width="4" height="40" fill="#2a1c3e" /><circle cx="0" cy="710" r="5" fill="#ff3af2" filter="url(#gb-glow-sm)" /></g>
			<g transform="translate(1300 0)"><ellipse cx="0" cy="764" rx="140" ry="34" fill="#00f5d4" fill-opacity="0.12" filter="url(#gb-glow)" /><rect x="-2" y="710" width="4" height="40" fill="#2a1c3e" /><circle cx="0" cy="710" r="5" fill="#00f5d4" filter="url(#gb-glow-sm)" /></g>
		</g>

		<!-- traffic: cars cruise the street rightward and loop -->
		<g class="gb-scene__traffic">
			<g class="gb-scene__car" transform="translate(120 748)"><PixelSprite grid={CAR} palette={CAR_PALETTES[0]} cell={2.6} /></g>
			<g class="gb-scene__car" transform="translate(470 752)"><PixelSprite grid={CAR} palette={CAR_PALETTES[1]} cell={2.6} /></g>
			<g class="gb-scene__car" transform="translate(820 748)"><PixelSprite grid={CAR} palette={CAR_PALETTES[2]} cell={2.6} /></g>
			<g class="gb-scene__car" transform="translate(1150 752)"><PixelSprite grid={CAR} palette={CAR_PALETTES[3]} cell={2.6} /></g>
		</g>

		<!-- a person strolling + a mouse scurrying along the curb -->
		<g class="gb-scene__person" transform="translate(300 724)">
			<g class="px-frame" data-frame="a"><PixelSprite grid={PERSON_A} palette={PERSON_PAL} cell={4} /></g>
			<g class="px-frame" data-frame="b" display="none"><PixelSprite grid={PERSON_B} palette={PERSON_PAL} cell={4} /></g>
		</g>
		<g class="gb-scene__mouse" transform="translate(660 747)">
			<g class="px-frame" data-frame="a"><PixelSprite grid={MOUSE_A} palette={MOUSE_PAL} cell={3} /></g>
			<g class="px-frame" data-frame="b" display="none"><PixelSprite grid={MOUSE_B} palette={MOUSE_PAL} cell={3} /></g>
		</g>

		<!-- cinematic vignette -->
		<rect class="gb-scene__vignette" x="0" y="0" width="1440" height="900" fill="url(#gb-vignette)" />
	</svg>
</div>

<!-- Cross-browser (Firefox-safe) motion: JS drives the SVG transforms via
     setAttribute in a RAF loop (CSS transform on SVG is flaky in Firefox; SMIL
     is gate-blocked). CSP-safe; respects reduced-motion. -->
<script src="../../scripts/hero/scene.ts"></script>
