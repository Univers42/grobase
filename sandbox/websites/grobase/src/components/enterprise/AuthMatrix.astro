---
// ── AUTH MATRIX — the enterprise sign-on detail. A compact row per mechanism
// (SAML / SCIM / OIDC / passkeys) with an honest status. Honest by construction:
// these wire through the control plane and are verified against a provider
// before any go-live, so they read as "on the roadmap", not "live today".
import Icon from '../ui/Icon.astro';

type Row = { icon: string; accent: 1 | 2 | 3 | 4 | 5; name: string; detail: string; status: string };

const ROWS: Row[] = [
	{
		icon: 'lock',
		accent: 2,
		name: 'SAML 2.0 single sign-on',
		detail: 'Federate logins through your existing identity provider — your directory stays the source of truth.',
		status: 'Roadmap',
	},
	{
		icon: 'users',
		accent: 1,
		name: 'SCIM provisioning',
		detail: 'Users and groups are created, updated, and de-provisioned automatically as your directory changes.',
		status: 'Roadmap',
	},
	{
		icon: 'key',
		accent: 3,
		name: 'OpenID Connect',
		detail: 'Standards-based OIDC for identity providers and apps that prefer it over SAML.',
		status: 'Roadmap',
	},
	{
		icon: 'shield',
		accent: 5,
		name: 'Passkeys (WebAuthn)',
		detail: 'Phishing-resistant, password-free sign-in backed by device biometrics and security keys.',
		status: 'Roadmap',
	},
];
---

<ul class="gb-ent-auth" role="list">
	{ROWS.map((r) => (
		<li class={`gb-ent-auth__row accent-${r.accent}`} data-rise>
			<span class="gb-ent-auth__icon" aria-hidden="true">
				<Icon name={r.icon} size={22} />
			</span>
			<div class="gb-ent-auth__text">
				<h3 class="gb-ent-auth__name">
					{r.name}
					<span class="gb-ent-auth__status">{r.status}</span>
				</h3>
				<p class="gb-ent-auth__detail">{r.detail}</p>
			</div>
		</li>
	))}
</ul>
