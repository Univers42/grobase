---
// ── DocsLayout — the documentation shell.
//
// Layout + Header + Footer wrapped around a three-column docs grid:
//   LEFT   auto-generated sidebar (collection → sections → pages)
//   CENTER breadcrumb + rendered markdown (<slot/>) + prev/next pager
//   RIGHT  "On this page" TOC (from the page's headings) with scroll-spy
//
// Premium-minimal: a calm, restrained header band; the dopamine energy stays in
// the accents (kicker pill, sidebar active rail, one serif-italic accent word).
// Everything is CSP-safe — colour/offset via classes, the only JS is the bundled
// toc scroll-spy + mobile drawer module (no inline handlers, no inline style).
import { getCollection } from 'astro:content';
import Layout from './Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Icon from '../components/ui/Icon.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import DocsToc from '../components/docs/DocsToc.astro';
import DocsBreadcrumb from '../components/docs/DocsBreadcrumb.astro';
import DocsPager from '../components/docs/DocsPager.astro';
import { buildNav, neighbours } from '../components/docs/nav';
import { SITE } from '../data/site';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}
interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	title: string;
	description: string;
	/** active doc slug ("guides/realtime") — null on the docs home */
	activeSlug?: string | null;
	/** rendered-page headings for the TOC (omit on the docs home) */
	headings?: Heading[];
	/** breadcrumb trail (Docs › … is built by the caller) */
	crumbs?: Crumb[];
	/** show the prev/next pager (off on the docs home) */
	pager?: boolean;
	/** a short kicker for the page header band */
	kicker?: string;
}

const {
	title,
	description,
	activeSlug = null,
	headings = [],
	crumbs = [{ label: 'Docs' }],
	pager = true,
	kicker = 'Documentation',
} = Astro.props;

// One source of truth for the nav: the docs collection itself.
const entries = await getCollection('docs');
const sections = buildNav(entries);
const { prev, next } = activeSlug ? neighbours(sections, activeSlug) : { prev: null, next: null };

const pageTitle = `${title} — ${SITE.name} docs`;
const hasToc = headings.some((h) => h.depth === 2 || h.depth === 3);
---

<Layout title={pageTitle} description={description} image="/og/home.png">
	<div class="gb-shell">
		<Header />
		<main id="main-content" class="gb-docs" data-docs-shell>
			<!-- restrained page-header band: kicker + title + one serif-italic accent word -->
			<div class="gb-docs-band">
				<div class="gb-container gb-docs-band__inner">
					<p class="gb-kicker accent-2"><Icon name="book-open" size={15} class="gb-docs-band__kicon" /> {kicker}</p>
					<h1 class="gb-docs-band__title">{title}</h1>
					<p class="gb-docs-band__sub">{description}</p>
				</div>
			</div>

			<div class="gb-container gb-docs-grid">
				<!-- mobile-only control: toggles the left sidebar drawer -->
				<button
					type="button"
					class="gb-docs-navbtn"
					data-docs-nav-toggle
					aria-expanded="false"
					aria-controls="gb-docs-sidebar"
				>
					<Icon name="menu" size={18} class="gb-docs-navbtn__icon" />
					<span>Browse docs</span>
				</button>

				<!-- LEFT: auto-generated sidebar (a div wrapper — the inner <nav
				     aria-label="Documentation"> is the labelled landmark, so this
				     stays a plain element to avoid a second unnamed complementary landmark) -->
				<div id="gb-docs-sidebar" class="gb-docs-side" data-docs-sidebar>
					<DocsSidebar sections={sections} active={activeSlug} />
				</div>
				<!-- backdrop closes the drawer on mobile -->
				<div class="gb-docs-backdrop" data-docs-nav-backdrop aria-hidden="true"></div>

				<!-- CENTER: breadcrumb + article + pager -->
				<article class="gb-docs-main">
					<DocsBreadcrumb crumbs={crumbs} />
					<div class="gb-docs-prose" data-rise>
						<slot />
					</div>
					{pager && <DocsPager prev={prev} next={next} />}
				</article>

				<!-- RIGHT: on-this-page TOC -->
				{
					hasToc && (
						<div class="gb-docs-aside">
							<DocsToc headings={headings} />
						</div>
					)
				}
			</div>
		</main>
		<Footer />
	</div>
</Layout>

<script>
	import '../scripts/docs/toc';
</script>
