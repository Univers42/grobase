---
// Per-tier advantages vs trade-offs, with a <details> drill-down ("know more").
// Each card carries data-col so the selected plan above highlights here too.
import { VERDICTS } from '../../data/pricing-matrix';
---

<div class="gb-tradeoffs" data-rise>
	{VERDICTS.map((vd) => (
		<article class={`gb-tradeoff tier--${vd.id}`} data-col={vd.id}>
			<h3 class="gb-tradeoff__name">{vd.name}</h3>
			<div class="gb-tradeoff__cols">
				<div class="gb-tradeoff__pros">
					<p class="gb-tradeoff__label">Advantages</p>
					<ul role="list">{vd.advantages.map((a) => <li>{a}</li>)}</ul>
				</div>
				<div class="gb-tradeoff__cons">
					<p class="gb-tradeoff__label">Trade-offs</p>
					<ul role="list">{vd.tradeoffs.map((t) => <li>{t}</li>)}</ul>
				</div>
			</div>
			<details class="gb-tradeoff__more">
				<summary>When to choose it — and when you'll outgrow it</summary>
				<p><strong>Best when:</strong> {vd.bestWhen}</p>
				<p><strong>Outgrow it when:</strong> {vd.outgrowWhen}</p>
			</details>
		</article>
	))}
</div>
