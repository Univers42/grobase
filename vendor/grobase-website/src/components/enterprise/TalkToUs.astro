---
// ── TALK TO US — the procurement CTA. Honest, low-friction: a short list of what
// a procurement / security review can expect, plus two real actions (email +
// open source). No fake "request a demo" form that goes nowhere, no invented SLA.
import Icon from '../ui/Icon.astro';
import { SITE } from '../../data/site';

type Item = { icon: string; accent: 1 | 2 | 3 | 4 | 5; text: string };

const CHECKLIST: Item[] = [
	{ icon: 'shield', accent: 2, text: 'Security & architecture review with the people who built it' },
	{ icon: 'file-text', accent: 4, text: 'Compliance posture, data-handling and the audit-log export' },
	{ icon: 'server', accent: 3, text: 'Self-host, managed-cloud, or a mix — sized to your isolation needs' },
	{ icon: 'git-branch', accent: 5, text: 'An honest read on what is shipped today and what is on the roadmap' },
];
---

<div class="gb-ent-talk liquid-glass" data-rise>
	<div class="gb-ent-talk__intro">
		<p class="gb-kicker accent-1"><Icon name="handshake" size={16} /> Procurement &amp; security</p>
		<h2 id="talk-title">Talk to the people who build it.</h2>
		<p class="gb-lede">
			No call centre, no scripted demo. A direct conversation about whether Grobase fits your
			organization — its controls, its isolation, and where it honestly is on the roadmap.
		</p>
		<div class="gb-ent-talk__ctas">
			<a class="gb-btn gb-btn--primary" href="mailto:enterprise@grobase.dev?subject=Grobase%20enterprise%20enquiry">Talk to us</a>
			<a class="gb-btn gb-btn--ghost" href={SITE.repoUrl} rel="noopener">Read the source first</a>
		</div>
	</div>
	<ul class="gb-ent-talk__list" role="list">
		{CHECKLIST.map((c) => (
			<li class={`gb-ent-talk__item accent-${c.accent}`}>
				<span class="gb-ent-talk__icon" aria-hidden="true"><Icon name={c.icon} size={20} /></span>
				<span>{c.text}</span>
			</li>
		))}
	</ul>
</div>
