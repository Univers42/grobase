---
// ── ENTERPRISE HERO — restrained, premium, cinematic. The least information
// possible: a single liquid-glass kicker pill, a short serif-accented headline,
// one line of lede, two CTAs, and a local dashboard-mock visual that blends into
// the canvas with a bottom fade and a gentle CSS scroll-parallax. No stats wall,
// no floaters storm — negative space does the talking. All motion is CSS
// scroll-driven / reduced-motion-gated; zero inline style=, zero external assets.
import Icon from '../ui/Icon.astro';
---

<section class="gb-section gb-ent-hero" aria-labelledby="ent-hero-title">
	<div class="gb-container gb-ent-hero__inner">
		<p class="gb-ent-hero__pill liquid-glass">
			<Icon name="shield" size={16} class="accent-2" />
			<span>Enterprise &amp; B2B · self-host or managed cloud</span>
		</p>
		<h1 id="ent-hero-title" class="gb-ent-hero__title">
			One backend, <em class="serif-italic">governed</em> for the whole organization.
		</h1>
		<p class="gb-lede gb-ent-hero__lede">
			Organizations, roles, enterprise sign-on, tamper-evident audit, per-tenant isolation and
			backup — the controls a security team asks for, on the same code that runs the 5&nbsp;MB binary.
		</p>
		<div class="gb-ent-hero__ctas">
			<a class="gb-btn gb-btn--primary" href="#talk">Talk to us</a>
			<a class="gb-btn gb-btn--ghost" href="#capabilities">See the capabilities</a>
		</div>
	</div>

	{/* Cinematic visual: local SVG mock, luminosity-blended, fades into the void,
	    drifts on scroll. Decorative → aria-hidden, absolute → zero CLS. */}
	<div class="gb-ent-hero__visual" aria-hidden="true">
		<img
			class="gb-ent-hero__mock blend-luminosity parallax parallax--slow"
			src="/img/dashboard-mock.svg"
			alt=""
			width="1280"
			height="720"
			loading="eager"
			decoding="async"
		/>
		<span class="premium-fade-bottom"></span>
	</div>
</section>
