---
// ── SolutionPainGrid — the "pain → how Grobase solves it" grid.
// Renders the data file's points[] as a broken-grid of cards, one <Icon> per
// point in a rotating accent (.rotate-accents). Each card frames the audience's
// real need and the concrete capability that answers it — straight from
// solutions.ts, no invented numbers, no competitor mentions. Decoration is
// absolute (zero-CLS) and aria-hidden; cards rise on scroll via [data-rise].
import Icon from '../ui/Icon.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import type { SolutionPoint } from '../../data/solutions';

type Props = {
	points: SolutionPoint[];
	/** audience title, used in the section heading */
	title: string;
	id: string;
};

const { points, title, id } = Astro.props;
---

<section class="gb-section gb-section--dim gb-sol-grid has-pat-dots" aria-labelledby={id}>
	<p class="bgword bgword--right accent-5" aria-hidden="true">WHY</p>
	<span class="floater floater--lg floater--tr accent-2 animate-float" aria-hidden="true"></span>
	<span class="floater floater--diamond floater--bl accent-4 animate-float-reverse" aria-hidden="true"></span>
	<span class="floater floater--sm floater--ml accent-3" aria-hidden="true"></span>

	<div class="gb-container">
		<SectionHeading
			kicker="Pain → solved"
			title={`What ${title.toLowerCase()} get out of one backend.`}
			lede="No per-project server code, no rewrite as you grow — every capability below is built in and the same SDK reaches all of it."
			id={id}
			accent={2}
		/>

		<ul class="gb-sol-points rotate-accents" role="list">
			{points.map((p) => (
				<li class="gb-sol-point" data-rise>
					<span class="gb-sol-point__icon" aria-hidden="true">
						<Icon name={p.icon} size={26} />
					</span>
					<h3 class="gb-sol-point__title">{p.title}</h3>
					<p class="gb-sol-point__body">{p.body}</p>
					<span class="gb-sol-point__rule" aria-hidden="true"></span>
				</li>
			))}
		</ul>
	</div>
</section>
