---
// ── AudienceGrid — the "Who is it for?" overview grid (index page).
// Links all nine audiences as an icon grid, each card carrying the audience's
// own icon (rotating accent via .rotate-accents), title and one-line headline
// from solutions.ts. Cards are links; whole card is the hit target. Decoration
// is absolute + aria-hidden (zero-CLS); cards rise on scroll via [data-rise].
import Icon from '../ui/Icon.astro';
import type { Solution } from '../../data/solutions';

type Props = {
	solutions: Solution[];
};

const { solutions } = Astro.props;
---

<ul class="gb-sol-audiences rotate-accents" role="list">
	{solutions.map((s) => (
		<li class="gb-sol-aud" data-rise>
			<a class="gb-sol-aud__link" href={`/solutions/${s.slug}/`} aria-label={`Grobase for ${s.title}`}>
				<span class="gb-sol-aud__icon" aria-hidden="true">
					<Icon name={s.icon} size={28} />
				</span>
				<h2 class="gb-sol-aud__title">{s.title}</h2>
				<p class="gb-sol-aud__line">{s.sub}</p>
				<span class="gb-sol-aud__go" aria-hidden="true">Explore →</span>
			</a>
		</li>
	))}
</ul>
