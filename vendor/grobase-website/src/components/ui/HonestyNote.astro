---
import Icon from './Icon.astro';

type Props = {
	title: string;
	/** Tint for the fat left bar + glow (1–5). Decoration only. */
	accent?: 1 | 2 | 3 | 4 | 5;
};
const { title, accent = 3 } = Astro.props;
const accClass = `accent-${accent}`;
---

<div class={`gb-honesty ${accClass}`}>
	<span class="gb-honesty__badge animate-wiggle" aria-hidden="true"><Icon name="zap" size={20} /></span>
	<p><strong>{title}</strong></p>
	<p><slot /></p>
</div>
