---
// ── DocsSidebar — the LEFT navigation, auto-built from the docs collection.
// Grouped by frontmatter `section` (reading order fixed in nav.ts), sorted by
// `order`. The active page is marked aria-current="page" so it's announced AND
// styled without any inline attribute. A real <nav> with a heading per group
// keeps it keyboard- and screen-reader-navigable.
import Icon from '../ui/Icon.astro';
import type { DocNavSection } from './nav';

interface Props {
	sections: DocNavSection[];
	/** the active doc slug, e.g. "guides/realtime" — null on the docs home */
	active: string | null;
}

const { sections, active } = Astro.props;

// One small icon per section header, by name in the fixed registry.
const SECTION_ICON: Record<string, string> = {
	'Getting started': 'rocket',
	Guides: 'book-open',
	'Self-hosting': 'server',
	Security: 'shield',
};
---

<nav class="gb-docs-nav" aria-label="Documentation">
	{
		sections.map((group) => (
			<div class="gb-docs-nav__group">
				<p class="gb-docs-nav__title">
					<Icon name={SECTION_ICON[group.section] ?? 'file-text'} size={16} class="gb-docs-nav__ticon" />
					{group.section}
				</p>
				<ul class="gb-docs-nav__list">
					{group.items.map((item) => (
						<li>
							<a
								class="gb-docs-nav__link"
								href={item.href}
								aria-current={item.slug === active ? 'page' : undefined}
							>
								{item.title}
							</a>
						</li>
					))}
				</ul>
			</div>
		))
	}
</nav>
