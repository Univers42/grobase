---
// ── FOOTER — the premium multi-column close of every page.
//
// Rich, not "almost nothing": a liquid-glass brand block (mark + name, tagline,
// one honest line, a social row of <Icon> with real accessible names), the
// FOOTER_GROUPS link columns (accents rotate across the headings via
// .rotate-accents), and a bottom bar carrying the © line, the "every number is
// live-measured" honesty note, and the product one-liner.
//
// Data is read from the single sources of truth: SITE (site.ts) + FOOTER_GROUPS
// and SOCIAL (nav.ts). No invented links — pages that don't exist yet point at
// the nearest real page in the data, so nothing 404s.
//
// CSP: zero inline style= / zero on* handlers. Colour/offset come from classes
// (.accent-N, :nth-child rules in _footer.scss). Icons render via <Icon>; social
// icons get a `title` so they are meaningful (role=img + accessible name). The
// social links to the repo open in a new tab; the RSS feed is a LOCAL path.
import Icon from '../ui/Icon.astro';
import { FOOTER_GROUPS, SOCIAL } from '../../data/nav';
import { SITE } from '../../data/site';

const year = new Date().getFullYear();
// External destinations (the repo + social) open in a new tab; the local RSS
// path stays same-tab. A link is external when it isn't a site-relative path.
const isExternal = (href: string) => !href.startsWith('/');
---

<footer class="gb-footer">
	<p class="bgword gb-footer__bgword" aria-hidden="true">GROBASE</p>
	<span class="floater floater--lg floater--bl accent-5 gb-footer__floater" aria-hidden="true"></span>
	<span class="floater floater--sm floater--tr accent-3 gb-footer__floater" aria-hidden="true"></span>

	<div class="gb-container gb-footer__body">
		<div class="gb-footer__grid">
			<!-- ── Brand block — liquid-glass, the premium anchor ── -->
			<div class="gb-footer__brandcol liquid-glass">
				<a class="gb-footer__brand" href="/">
					<span class="gb-footer__spark" aria-hidden="true">
						<Icon name="sparkle" size={26} />
					</span>
					<span class="gb-footer__name">{SITE.name}</span>
				</a>
				<p class="gb-footer__tag">{SITE.tagline}</p>
				<p class="gb-footer__oneliner">
					Self-hosted, engine-agnostic, honestly priced — one backend from a 5&nbsp;MB binary to a 10K-tenant platform.
				</p>

				<ul class="gb-footer__social">
					{SOCIAL.map((s) => (
						<li>
							<a
								class="gb-footer__sociallink"
								href={s.href}
								target={isExternal(s.href) ? '_blank' : undefined}
								rel={isExternal(s.href) ? 'noopener noreferrer' : undefined}
							>
								<Icon name={s.icon} size={20} title={s.label} />
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- ── Link columns — accents rotate across the headings ── -->
			<nav class="gb-footer__cols rotate-accents" aria-label="Footer">
				{FOOTER_GROUPS.map((group) => (
					<div class="gb-footer__col">
						<h2 class="gb-footer__coltitle">{group.title}</h2>
						<ul class="gb-footer__list">
							{group.links.map((link) => (
								<li>
									<a class="gb-footer__link" href={link.href}>{link.label}</a>
								</li>
							))}
						</ul>
					</div>
				))}
			</nav>
		</div>

		<!-- ── Bottom bar ── -->
		<div class="gb-footer__bar">
			<p class="gb-footer__copy">
				© {year} {SITE.name}.
				<span class="gb-footer__claim">Self-hosted, engine-agnostic, honestly priced.</span>
			</p>
			<p class="gb-footer__note">
				Every number on this site is live-measured on the real stack — not estimated, not rounded up.
			</p>
		</div>
	</div>
</footer>
