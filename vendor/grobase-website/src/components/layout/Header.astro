---
// ── HEADER — premium mega-menu. ───────────────────────────────────────────────
// Sticky top bar: brand · TOP_NAV (mega-menus + plain links) · "Start free" CTA.
// "Solutions"/"Resources" are <button aria-expanded aria-controls> that open
// liquid-glass mega-menu panels; "Enterprise"/"Pricing"/"Security" are plain links.
// Mobile (≤60rem): a hamburger toggles a drawer where the same buttons become
// accordions. Interactivity is enhanced by src/scripts/nav/megamenu.ts (CSP-safe:
// classes/attributes/aria only); a :focus-within CSS base reveals panels for
// keyboard + no-JS users. Nav data is the single source of truth in data/nav.ts.
import Icon from '../ui/Icon.astro';
import { SITE } from '../../data/site';
import { TOP_NAV, MENUS, ANNOUNCEMENT } from '../../data/nav';
import type { MenuKey } from '../../data/nav';

const current = Astro.url.pathname;
const isCurrent = (href: string) => (href === '/' ? current === '/' : current.startsWith(href.replace(/\/$/, '')));

// stable panel ids so the buttons' aria-controls resolve (and the script can find them)
const panelId = (key: MenuKey) => `gb-menu-${key}`;
const labels: Record<MenuKey, { frame: string; eyebrow: string }> = {
	solutions: { frame: 'Who is it for?', eyebrow: 'Solutions' },
	resources: { frame: 'Go further', eyebrow: 'Resources' },
};
---

<header class="gb-header" data-megamenu-root>
	<span class="floater floater--sm floater--tr accent-2 gb-header__floater" aria-hidden="true"></span>
	<div class="gb-container gb-header__inner">
		<a class="gb-header__brand" href="/">
			<svg class="gb-header__mark" viewBox="0 0 64 64" aria-hidden="true" fill="none">
				<path d="M46.5 21.5A17 17 0 1 0 49 32h-15" stroke="var(--gb-a2)" stroke-width="5" stroke-linecap="round" />
				<circle cx="46.5" cy="21.5" r="4.5" fill="var(--gb-a1)" />
				<circle cx="49" cy="32" r="3.5" fill="var(--gb-a3)" />
			</svg>
			<span class="gb-header__name">{SITE.name}</span>
		</a>

		<button
			class="gb-header__burger"
			type="button"
			aria-label="Open menu"
			aria-expanded="false"
			data-drawer-toggle
		>
			<Icon name="menu" size={26} class="gb-header__burger-open" />
			<Icon name="close" size={26} class="gb-header__burger-close" />
		</button>

		<nav class="gb-header__nav" aria-label="Main">
			{
				TOP_NAV.map((item) =>
					item.menu ? (
						<div class="gb-header__item" data-menu={item.menu}>
							<button
								class="gb-header__link gb-header__trigger"
								type="button"
								aria-expanded="false"
								aria-controls={panelId(item.menu)}
								data-menu-trigger={item.menu}
							>
								{item.label}
								<Icon name="chevron-down" size={16} class="gb-header__chevron" />
							</button>

							<div id={panelId(item.menu)} class="gb-mega liquid-glass" data-menu-panel={item.menu}>
								<div class="gb-mega__inner">
									<p class="gb-mega__frame">
										<span class="gb-mega__eyebrow">{labels[item.menu].eyebrow}</span>
										{labels[item.menu].frame}
									</p>

									<div class={`gb-mega__body gb-mega__body--${item.menu}`}>
										<ul class="gb-mega__grid rotate-accents" role="list">
											{MENUS[item.menu].map((link) => (
												<li>
													<a class="gb-mega__card" href={link.href}>
														<span class="gb-mega__icon">
															<Icon name={link.icon} size={22} />
														</span>
														<span class="gb-mega__text">
															<span class="gb-mega__label">{link.label}</span>
															<span class="gb-mega__blurb">{link.blurb}</span>
														</span>
													</a>
												</li>
											))}
										</ul>

										{item.menu === 'resources' && (
											<a class="gb-mega__feature liquid-glass" href={ANNOUNCEMENT.href}>
												<img
													class="gb-mega__feature-img"
													src={ANNOUNCEMENT.image}
													alt=""
													width="320"
													height="180"
													loading="lazy"
													decoding="async"
												/>
												<span class="gb-mega__feature-eyebrow gb-kicker">{ANNOUNCEMENT.eyebrow}</span>
												<span class="gb-mega__feature-title">{ANNOUNCEMENT.title}</span>
												<span class="gb-mega__feature-body">{ANNOUNCEMENT.body}</span>
												<span class="gb-mega__feature-cta">
													{ANNOUNCEMENT.cta}
													<Icon name="arrow-right" size={18} />
												</span>
											</a>
										)}
									</div>
								</div>
							</div>
						</div>
					) : (
						<a
							class="gb-header__link"
							href={item.href}
							aria-current={item.href && isCurrent(item.href) ? 'page' : undefined}
						>
							{item.label}
						</a>
					),
				)
			}

			<a class="gb-btn gb-btn--primary gb-header__cta" href="/pricing/">
				<Icon name="sparkle" size={18} class="gb-header__cta-spark" />Start free
			</a>
		</nav>
	</div>
</header>

<script src="../../scripts/nav/megamenu.ts"></script>
