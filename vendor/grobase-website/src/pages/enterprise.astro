---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import EnterpriseHero from '../components/enterprise/EnterpriseHero.astro';
import CapabilityGrid from '../components/enterprise/CapabilityGrid.astro';
import AuthMatrix from '../components/enterprise/AuthMatrix.astro';
import IsolationLadder from '../components/enterprise/IsolationLadder.astro';
import Manifesto from '../components/enterprise/Manifesto.astro';
import TalkToUs from '../components/enterprise/TalkToUs.astro';
import { SITE } from '../data/site';

const title = `Enterprise — ${SITE.name}`;
const description =
	'Grobase for organizations: orgs, teams and RBAC; enterprise sign-on (SAML 2.0, SCIM, OIDC, passkeys); tamper-evident exportable audit logs; four isolation models with dense multi-tenancy; per-tenant backup and observability; self-host or managed cloud — honest about what is shipped versus on the roadmap.';

const jsonLd = [
	{
		'@type': 'Product',
		name: `${SITE.name} Enterprise`,
		description,
		brand: { '@type': 'Brand', name: SITE.name },
	},
];
---

<Layout title={title} description={description} image="/og/pricing.png" jsonLd={jsonLd}>
	<div class="gb-shell">
		<Header />
		<main id="main-content">
			<EnterpriseHero />

			<section id="capabilities" class="gb-section gb-section--dim has-pat-dots" aria-labelledby="caps-title">
				<span class="floater floater--lg floater--tr accent-2 animate-float" aria-hidden="true"></span>
				<span class="floater floater--sm floater--ml accent-1" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="What an organization gets"
						title="The controls a security team asks for."
						lede="Built from real product features — orgs and RBAC, enterprise sign-on, tamper-evident audit, isolation you choose, per-tenant backup and observability. Each card says plainly whether it is shipped or still on the roadmap."
						id="caps-title"
						accent={2}
					/>
					<CapabilityGrid />
				</div>
			</section>

			<section class="gb-section" aria-labelledby="auth-title">
				<span class="floater floater--ring floater--mr accent-5 animate-spin-slow" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Bring your identity provider"
						title="Enterprise sign-on, wired through the control plane."
						lede="Your directory stays the source of truth. Each mechanism is verified against a real provider before it goes live — so these are listed honestly as roadmap, not shipped."
						id="auth-title"
						accent={5}
					/>
					<AuthMatrix />
				</div>
			</section>

			<section class="gb-section gb-section--dim has-pat-checker" aria-labelledby="iso-title">
				<span class="floater floater--lg floater--tl accent-3 animate-float-reverse" aria-hidden="true"></span>
				<span class="floater floater--diamond floater--br accent-1" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Pick your isolation"
						title="Four models, one codebase, no rewrite."
						lede="From a shared pool with per-request scoping to a dedicated database per tenant. Denser models are not less safe — isolation is enforced per request, which is what lets thousands of tenants share one pool."
						id="iso-title"
						accent={3}
					/>
					<IsolationLadder />
				</div>
			</section>

			<section class="gb-section gb-section--mesh" aria-labelledby="manifesto-title">
				<h2 id="manifesto-title" class="visually-hidden">Our enterprise principle</h2>
				<div class="gb-container">
					<Manifesto />
				</div>
			</section>

			<section id="talk" class="gb-section has-pat-dots" aria-labelledby="talk-title">
				<span class="floater floater--sm floater--tr accent-2 animate-float" aria-hidden="true"></span>
				<div class="gb-container">
					<TalkToUs />
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
