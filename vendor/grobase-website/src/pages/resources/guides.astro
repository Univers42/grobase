---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import ResourceHero from '../../components/resources/ResourceHero.astro';
import ResourceGrid from '../../components/resources/ResourceGrid.astro';
import Icon from '../../components/ui/Icon.astro';
import { SITE } from '../../data/site';
import { GUIDES } from '../../data/resources';

const title = `Guides — ${SITE.name}`;
const description = GUIDES.intro;

const jsonLd = [
	{
		'@type': 'CollectionPage',
		name: title,
		description,
		hasPart: GUIDES.items.map((g) => ({ '@type': 'WebPage', name: g.title, description: g.body })),
	},
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
	<div class="gb-shell">
		<Header />
		<main id="main-content">
			<ResourceHero
				kicker="Guides"
				titleLead="Learn it by"
				titleAccent="doing."
				lede={GUIDES.intro}
				icon="book-open"
				id="guides-title"
			/>

			<section class="gb-section gb-section--dim gb-rsection" aria-labelledby="guides-list-title">
				<div class="gb-container">
					<div class="gb-section__head accent-5" data-rise>
						<p class="gb-kicker"><span aria-hidden="true">→</span> Task-first walkthroughs</p>
						<h2 id="guides-list-title" class="tshadow-mega">Pick a feature, ship it</h2>
						<p class="gb-lede">
							Each guide takes you from a fresh instance to a working feature. The full set lives in the docs — start with
							one below.
						</p>
					</div>
					<ResourceGrid items={GUIDES.items} />

					<aside class="gb-rcta liquid-glass" data-rise>
						<div class="gb-rcta__copy">
							<p class="gb-rcta__eyebrow accent-2">All guides in one place</p>
							<p class="gb-rcta__lead">
								The complete, versioned set of guides — auth, realtime, storage, functions and multi-engine queries —
								lives in the documentation.
							</p>
						</div>
						<a class="gb-btn gb-btn--primary" href="/docs/guides/">
							<span>Open the guides</span>
							<Icon name="arrow-right" size={18} />
						</a>
					</aside>
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
