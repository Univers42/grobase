---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import ResourceHero from '../../components/resources/ResourceHero.astro';
import ResourceGrid from '../../components/resources/ResourceGrid.astro';
import Icon from '../../components/ui/Icon.astro';
import { SITE } from '../../data/site';
import { CONNECTORS } from '../../data/resources';

const title = `Connectors — ${SITE.name}`;
const description = CONNECTORS.intro;

// The honest claim: ONE uniform API, eight engines. Each verb works the same way
// across every adapter. These are real capabilities of the Rust data plane.
const UNIFORM_VERBS = [
	{ icon: 'database', label: 'Read & write', note: 'CRUD with the same call shape on every engine.' },
	{ icon: 'search', label: 'Search', note: 'Full-text and vector search across the data.' },
	{ icon: 'chart', label: 'Aggregate', note: 'count, sum, avg, min, max and group-by.' },
	{ icon: 'realtime', label: 'Subscribe', note: 'Change-data-capture feeds for live updates.' },
	{ icon: 'lock', label: 'Owner-scope', note: 'Per-request isolation — never pool state.' },
];

const jsonLd = [
	{
		'@type': 'CollectionPage',
		name: title,
		description,
		hasPart: CONNECTORS.items.map((c) => ({ '@type': 'WebPage', name: c.title, description: c.body })),
	},
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
	<div class="gb-shell">
		<Header />
		<main id="main-content">
			<ResourceHero
				kicker="Connectors"
				titleLead="Eight engines,"
				titleAccent="one"
				titleTail="API."
				lede={CONNECTORS.intro}
				icon="connectors"
				id="connectors-title"
			/>

			{/* The uniform-API strip: the verbs that work identically on every engine. */}
			<section class="gb-section gb-section--dim gb-rsection" aria-labelledby="connectors-uniform-title">
				<div class="gb-container">
					<div class="gb-section__head accent-2" data-rise>
						<p class="gb-kicker"><span aria-hidden="true">→</span> One uniform API</p>
						<h2 id="connectors-uniform-title" class="tshadow-mega">The same five verbs, every engine</h2>
						<p class="gb-lede">
							Point Grobase at the database your data already lives in. Read, write, search, aggregate and subscribe
							through a single SDK — no per-engine rewrite, no data migration.
						</p>
					</div>

					<ul class="gb-rverbs" role="list">
						{
							UNIFORM_VERBS.map((v) => (
								<li class="gb-rverb" data-rise>
									<span class="gb-rverb__icon" aria-hidden="true">
										<Icon name={v.icon} size={22} />
									</span>
									<div class="gb-rverb__text">
										<span class="gb-rverb__label">{v.label}</span>
										<span class="gb-rverb__note">{v.note}</span>
									</div>
								</li>
							))
						}
					</ul>
				</div>
			</section>

			{/* The eight engine cards. */}
			<section class="gb-section gb-rsection" aria-labelledby="connectors-engines-title">
				<div class="gb-container">
					<div class="gb-section__head accent-4" data-rise>
						<p class="gb-kicker"><span aria-hidden="true">→</span> The eight engines</p>
						<h2 id="connectors-engines-title" class="tshadow-mega">Bring your own database</h2>
						<p class="gb-lede">
							Each adapter is first-class — owner-scoping is enforced per request on all of them, so a fix that works for
							one engine works for every engine.
						</p>
					</div>
					<ResourceGrid items={CONNECTORS.items} />

					<aside class="gb-rcta liquid-glass" data-rise>
						<div class="gb-rcta__copy">
							<p class="gb-rcta__eyebrow accent-1">Engine-agnostic by construction</p>
							<p class="gb-rcta__lead">
								The whole platform is one codebase across these engines. Read how the adapters stay uniform in the
								connectors guide.
							</p>
						</div>
						<a class="gb-btn gb-btn--ghost" href="/docs/guides/">
							<span>Read the guides</span>
							<Icon name="arrow-right" size={18} />
						</a>
					</aside>
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
