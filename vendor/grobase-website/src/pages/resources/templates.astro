---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import ResourceHero from '../../components/resources/ResourceHero.astro';
import ResourceGrid from '../../components/resources/ResourceGrid.astro';
import Icon from '../../components/ui/Icon.astro';
import { SITE } from '../../data/site';
import { TEMPLATES } from '../../data/resources';

const title = `Templates — ${SITE.name}`;
const description = TEMPLATES.intro;

const jsonLd = [
	{
		'@type': 'CollectionPage',
		name: title,
		description,
		hasPart: TEMPLATES.items.map((t) => ({ '@type': 'WebPage', name: t.title, description: t.body })),
	},
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
	<div class="gb-shell">
		<Header />
		<main id="main-content">
			<ResourceHero
				kicker="Templates"
				titleLead="From zero to a"
				titleAccent="running"
				titleTail="backend."
				lede={TEMPLATES.intro}
				icon="templates"
				id="templates-title"
			/>

			<section class="gb-section gb-section--dim gb-rsection" aria-labelledby="templates-list-title">
				<div class="gb-container">
					<div class="gb-section__head accent-3" data-rise>
						<p class="gb-kicker"><span aria-hidden="true">→</span> Starter projects</p>
						<h2 id="templates-list-title" class="tshadow-mega">Clone, point, ship</h2>
						<p class="gb-lede">
							Each starter is wired to the SDK on day one — accounts, owner-scoped data and realtime already connected.
							Point it at your instance and build.
						</p>
					</div>
					<ResourceGrid items={TEMPLATES.items} />

					<aside class="gb-rcta liquid-glass" data-rise>
						<div class="gb-rcta__copy">
							<p class="gb-rcta__eyebrow accent-4">Same SDK, every tier</p>
							<p class="gb-rcta__lead">
								A template that runs on the 5 MB nano binary runs unchanged on the multi-tenant platform — you graduate
								tiers, you never rewrite.
							</p>
						</div>
						<a class="gb-btn gb-btn--ghost" href="/docs/">
							<span>Read the docs</span>
							<Icon name="arrow-right" size={18} />
						</a>
					</aside>
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
