---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import GalaxyCanvas from '../components/galaxy/GalaxyCanvas.astro';
import Hero from '../components/sections/Hero.astro';
import UseCases from '../components/sections/UseCases.astro';
import WhatYouGet from '../components/sections/WhatYouGet.astro';
import Manifesto from '../components/sections/Manifesto.astro';
import HonestRoadmap from '../components/sections/HonestRoadmap.astro';
import FinalCta from '../components/sections/FinalCta.astro';
import { SITE } from '../data/site';

const jsonLd = [
	{
		'@type': 'SoftwareApplication',
		name: SITE.name,
		applicationCategory: 'DeveloperApplication',
		operatingSystem: 'Linux, Docker',
		description: SITE.description,
		offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	},
];
---

<Layout jsonLd={jsonLd}>
	<GalaxyCanvas />
	<div class="gb-shell">
		<Header />
		<main id="main-content">
			<Hero />
			<UseCases />
			<WhatYouGet />
			<Manifesto />
				<HonestRoadmap />
			<FinalCta />
		</main>
		<Footer />
	</div>
</Layout>
