---
// SECURITY — the public, HONEST security & compliance page. Modeled on the
// structure of lovable.dev/security, but in soft framing: no hard attestation claim
// (kernel rule #4; gate m144 + e2e grep the rendered body for the substring), no
// invented uptime/RTO/RPO. Every control mirrors config/trust/posture.json via
// src/data/security.ts; statuses are the honest ones (WAF + encryption-at-rest
// stay Roadmap). Strict hashed CSP: zero inline style=, zero new inline scripts.
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import HonestyNote from '../components/ui/HonestyNote.astro';
import Icon from '../components/ui/Icon.astro';
import SecurityHero from '../components/security/SecurityHero.astro';
import ControlSection from '../components/security/ControlSection.astro';
import ComplianceBadges from '../components/security/ComplianceBadges.astro';
import TrustCenterCTA from '../components/security/TrustCenterCTA.astro';
import Faq from '../components/pricing/Faq.astro';
import { SITE } from '../data/site';
import { ISOLATION_MODELS } from '../data/isolation';
import { SECURITY_CONTROLS, COMPLIANCE_BADGES, SECURITY_FAQ } from '../data/security';

const title = `Security — ${SITE.name}`;
const description =
	'How Grobase is defended, stated honestly: an audit-ready posture (no formal external attestation yet), tamper-evident audit, per-request isolation, fine-grained ABAC, orgs/SSO/SCIM/passkeys, abuse guards and spend caps, a locked-down supply chain, GDPR data-subject rights built in, and a published vulnerability-disclosure path. SOC 2 audit-ready · ISO 27001 aligned · GDPR-compliant posture.';

// Pull controls by id so each section shows exactly the controls it should — the
// list (and statuses) stays single-sourced in src/data/security.ts.
const byId = new Map(SECURITY_CONTROLS.map((c) => [c.id, c]));
const pick = (...ids: string[]) => ids.map((id) => byId.get(id)).filter((c): c is NonNullable<typeof c> => Boolean(c));

const accessControls = pick('organizations-rbac', 'enterprise-passkeys', 'sso-oidc', 'scim-provisioning', 'abac-pdp');
const guardrailControls = pick('abuse-guard', 'spend-caps');
const secretsControls = pick('secrets-management', 'cmek-byok', 'network-access-control');
const isolationControls = pick('per-tenant-isolation');
const monitoringControls = pick('tamper-evident-audit', 'data-portability-export', 'hard-erase');
const scanningControls = pick('supply-chain', 'compliance-matrices');
const infraControls = pick('encryption-in-transit', 'encryption-at-rest', 'waf');
const disclosureControls = pick('vulnerability-disclosure');
const complianceControls = pick('soc2-lite-evidence', 'formal-soc2-type2', 'formal-iso27001', 'sla-uptime');

const jsonLd = [
	{
		'@type': 'WebPage',
		name: title,
		description,
		about: { '@type': 'Thing', name: 'Application security & compliance posture' },
	},
	{
		'@type': 'FAQPage',
		mainEntity: SECURITY_FAQ.map((f) => ({
			'@type': 'Question',
			name: f.q,
			acceptedAnswer: { '@type': 'Answer', text: f.a },
		})),
	},
];
---

<Layout title={title} description={description} image="/og/home.png" jsonLd={jsonLd}>
	<div class="gb-shell">
		<Header />
		<main id="main-content">
			<SecurityHero />

			<!-- ── Enterprise security controls (overview) ───────────────────────── -->
			<section id="controls" class="gb-section gb-section--dim has-pat-dots" aria-labelledby="controls-title">
				<p class="bgword bgword--left accent-2" aria-hidden="true">SAFE</p>
				<span class="floater floater--lg floater--tl accent-2 animate-float" aria-hidden="true"></span>
				<span class="floater floater--diamond floater--tr accent-1 animate-float-reverse" aria-hidden="true"></span>
				<span class="floater floater--sm floater--mr accent-3" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Enterprise security controls"
						title="Secure by design — and honest about the edges."
						lede="Every control below is mirrored from our published posture. Each carries its real status: Implemented, Partial, or Roadmap. Nothing here is aspirational dressed up as done."
						id="controls-title"
						accent={2}
					/>
					<HonestyNote title="Audit-ready posture — no formal external attestation yet." accent={4}>
						We collect continuous evidence and map every control to SOC 2, GDPR and ISO 27001. A SOC 2
						Type II report and ISO 27001 certification are on the roadmap — a report is available under NDA
						on request. We would rather under-claim and be trusted.
					</HonestyNote>
				</div>
			</section>

			<!-- ── Access & identity ─────────────────────────────────────────────── -->
			<section class="gb-section has-pat-stripes" aria-labelledby="access-title">
				<p class="bgword bgword--right accent-1" aria-hidden="true">WHO</p>
				<span class="floater floater--lg floater--tr accent-1 animate-float" aria-hidden="true"></span>
				<span class="floater floater--square floater--ml accent-5 animate-spin-slow" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Access & identity"
						title="Prove who you are. See only what is yours."
						lede="Organizations with role-based access, phishing-resistant passkeys, enterprise SSO and SCIM provisioning, all under one fine-grained policy decision point."
						id="access-title"
						accent={1}
					/>
					<ControlSection title="Identity & access controls" id="access-controls" controls={accessControls} accent={1} />
				</div>
			</section>

			<!-- ── Guardrails & abuse ────────────────────────────────────────────── -->
			<section class="gb-section gb-section--dim has-pat-checker" aria-labelledby="guardrails-title">
				<p class="bgword bgword--left accent-3" aria-hidden="true">GUARD</p>
				<span class="floater floater--lg floater--tl accent-3 animate-float-reverse" aria-hidden="true"></span>
				<span class="floater floater--ring floater--mr accent-2 animate-spin-slow" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Guardrails & abuse"
						title="Abuse and runaway cost, capped at the source."
						lede="A per-tenant abuse guard throttles hostile load, and per-tenant spend caps bound runaway cost on the data path — one noisy or malicious tenant cannot take down the rest or run up the bill."
						id="guardrails-title"
						accent={3}
					/>
					<ControlSection title="Abuse & cost guardrails" id="guardrail-controls" controls={guardrailControls} accent={3} />
				</div>
			</section>

			<!-- ── Secrets management ────────────────────────────────────────────── -->
			<section class="gb-section has-pat-dots" aria-labelledby="secrets-title">
				<p class="bgword bgword--right accent-5" aria-hidden="true">KEYS</p>
				<span class="floater floater--lg floater--tr accent-5 animate-float" aria-hidden="true"></span>
				<span class="floater floater--diamond floater--bl accent-4 animate-float-reverse" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Secrets management"
						title="Credentials live in Vault — never in an image."
						lede="Secrets are fetched from HashiCorp Vault at start, with short-lived dynamic database credentials to shrink blast radius and customer-managed keys that can crypto-shred a mount on revocation."
						id="secrets-title"
						accent={5}
					/>
					<ControlSection title="Secrets & key management" id="secret-controls" controls={secretsControls} accent={5} />
				</div>
			</section>

			<!-- ── Data residency (self-host framing) ────────────────────────────── -->
			<section class="gb-section gb-section--dim gb-section--mesh has-pat-stripes" aria-labelledby="residency-title">
				<p class="bgword bgword--left accent-2" aria-hidden="true">YOURS</p>
				<span class="floater floater--lg floater--tl accent-2 animate-float" aria-hidden="true"></span>
				<span class="floater floater--sm floater--mr accent-1" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Data residency"
						title="Self-host, and the boundary is yours."
						lede="The strongest residency story is owning it. Run the whole stack in your own infrastructure and region — no Grobase subprocessor ever sees self-hosted data. In the managed cloud, residency is set per deployment and stated up front."
						id="residency-title"
						accent={2}
					/>
				</div>
			</section>

			<!-- ── Isolation by design ───────────────────────────────────────────── -->
			<section class="gb-section has-pat-checker" aria-labelledby="isolation-title">
				<p class="bgword bgword--right accent-4" aria-hidden="true">WALLS</p>
				<span class="floater floater--lg floater--tr accent-4 animate-float" aria-hidden="true"></span>
				<span class="floater floater--ring floater--ml accent-3 animate-spin-slow" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Isolation by design"
						title="Pick the wall your tenants need."
						lede="Isolation is re-stamped per request, not held in pool state — so thousands of tenants can share one pool with byte-identical results, and you choose the model per mount."
						id="isolation-title"
						accent={4}
					/>
					<ControlSection title="Per-request isolation" id="isolation-controls" controls={isolationControls} accent={4} />
					<div class="gb-sec-iso">
						<h3 class="gb-sec-iso__title">Four isolation models, selectable per mount</h3>
						<ul class="gb-sec-iso__grid rotate-accents" role="list">
							{
								ISOLATION_MODELS.map((m) => (
									<li class="gb-sec-iso__card" data-rise>
										<h4 class="gb-sec-iso__name">{m.name}</h4>
										<p class="gb-sec-iso__how">{m.how}</p>
										<dl class="gb-sec-iso__meta">
											<div>
												<dt>Cost</dt>
												<dd>{m.cost}</dd>
											</div>
											<div>
												<dt>Use when</dt>
												<dd>{m.when}</dd>
											</div>
										</dl>
									</li>
								))
							}
						</ul>
					</div>
				</div>
			</section>

			<!-- ── Continuous monitoring ─────────────────────────────────────────── -->
			<section class="gb-section gb-section--dim has-pat-dots" aria-labelledby="monitoring-title">
				<p class="bgword bgword--left accent-1" aria-hidden="true">WATCH</p>
				<span class="floater floater--lg floater--tl accent-1 animate-float-reverse" aria-hidden="true"></span>
				<span class="floater floater--square floater--mr accent-5 animate-spin-slow" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Continuous monitoring"
						title="An audit trail that can't be quietly rewritten."
						lede="Security-relevant events land in a hash-chained, tamper-evident audit log you can export. The chain is recomputable, so any insertion, edit or deletion is detectable after the fact."
						id="monitoring-title"
						accent={1}
					/>
					<ControlSection title="Audit, export & erasure" id="monitoring-controls" controls={monitoringControls} accent={1} />
				</div>
			</section>

			<!-- ── Automatic security scanning ───────────────────────────────────── -->
			<section class="gb-section has-pat-stripes" aria-labelledby="scanning-title">
				<p class="bgword bgword--right accent-3" aria-hidden="true">SCAN</p>
				<span class="floater floater--lg floater--tr accent-3 animate-float" aria-hidden="true"></span>
				<span class="floater floater--diamond floater--ml accent-2 animate-float-reverse" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Automatic security scanning"
						title="The supply chain is scanned on every change."
						lede="Frozen lockfiles, install scripts disabled, a dependency release-age floor, plus SAST, SCA and cargo-audit run in CI — closing the install-time code-execution path of a poisoned package."
						id="scanning-title"
						accent={3}
					/>
					<ControlSection title="Supply-chain & framework coverage" id="scanning-controls" controls={scanningControls} accent={3} />
				</div>
			</section>

			<!-- ── Protected infrastructure (honest partial/planned) ─────────────── -->
			<section class="gb-section gb-section--dim has-pat-checker" aria-labelledby="infra-title">
				<p class="bgword bgword--left accent-5" aria-hidden="true">CRYPTO</p>
				<span class="floater floater--lg floater--tl accent-5 animate-float" aria-hidden="true"></span>
				<span class="floater floater--ring floater--mr accent-4 animate-spin-slow" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Protected infrastructure"
						title="Encryption: what's enforced, and what's on the way."
						lede="Encryption in transit is enforced in max mode; encryption at rest and a managed L7 WAF are operator-provided today and on our roadmap. We label these honestly rather than imply they ship enforced by default."
						id="infra-title"
						accent={5}
					/>
					<ControlSection title="Transport, at-rest & edge" id="infra-controls" controls={infraControls} accent={5} />
				</div>
			</section>

			<!-- ── Vulnerability disclosure ──────────────────────────────────────── -->
			<section class="gb-section gb-section--mesh has-pat-dots" aria-labelledby="disclosure">
				<p class="bgword bgword--right accent-1" aria-hidden="true">TELL US</p>
				<span class="floater floater--lg floater--tr accent-1 animate-float" aria-hidden="true"></span>
				<span class="floater floater--diamond floater--bl accent-2 animate-float-reverse" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Vulnerability disclosure"
						title="See something? Tell us privately."
						lede="We treat good-faith security research as a gift. We work the fix with you — no legal threats, no surprises — and credit your finding with your consent."
						id="disclosure"
						accent={1}
					/>
					<ControlSection title="Coordinated disclosure" id="disclosure-controls" controls={disclosureControls} accent={1} />
					<p class="gb-sec-disclose__inline">
						Our contact and policy are published in
						<a class="gb-sec-disclose__src" href="/.well-known/security.txt">
							/.well-known/security.txt <Icon name="external-link" size={14} />
						</a>
						(RFC&nbsp;9116). Or email
						<a class="gb-sec-disclose__src" href="mailto:security@grobase.dev">security@grobase.dev</a>.
					</p>
				</div>
			</section>

			<!-- ── Compliance posture (the badges — soft framing, not hard badges) ── -->
			<section id="compliance" class="gb-section has-pat-stripes" aria-labelledby="compliance-title">
				<p class="bgword bgword--left accent-3" aria-hidden="true">HONEST</p>
				<span class="floater floater--lg floater--tl accent-3 animate-float-reverse" aria-hidden="true"></span>
				<span class="floater floater--ring floater--mr accent-2 animate-spin-slow" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading
						kicker="Compliance posture"
						title="Aligned, audit-ready, and honest about it."
						lede="We map our controls to the major frameworks and collect continuous evidence. Here is exactly where we stand — and what is still on the roadmap."
						id="compliance-title"
						accent={3}
					/>
					<ComplianceBadges badges={COMPLIANCE_BADGES} />
					<ControlSection title="Evidence, attestation & SLA — where they stand" id="compliance-controls" controls={complianceControls} accent={3} />
					<HonestyNote title="Posture, not paper we don't hold." accent={3}>
						SOC 2 is audit-ready with continuous evidence; ISO 27001 alignment is mapped with a drafted
						Statement of Applicability; GDPR data-subject rights are implemented and gate-proven. A formal
						external attestation is on the roadmap, not yet held. Reports and a DPA are available on
						request, some under NDA.
					</HonestyNote>
				</div>
			</section>

			<!-- ── FAQ ───────────────────────────────────────────────────────────── -->
			<section class="gb-section gb-section--dim has-pat-dots has-pat-checker" aria-labelledby="faq-title">
				<p class="bgword bgword--bottom accent-4" aria-hidden="true">ASK</p>
				<span class="floater floater--lg floater--tl accent-4 animate-float" aria-hidden="true"></span>
				<span class="floater floater--ring floater--tr accent-3 animate-spin-slow" aria-hidden="true"></span>
				<div class="gb-container">
					<SectionHeading kicker="Questions" title="Security FAQ" id="faq-title" accent={4} />
					<Faq items={SECURITY_FAQ} />
				</div>
			</section>

			<!-- ── Trust center / DPA / report-a-vulnerability CTA band ──────────── -->
			<section class="gb-section gb-section--mesh has-pat-stripes" aria-labelledby="trust-cta-title">
				<h2 id="trust-cta-title" class="visually-hidden">Trust center and contacts</h2>
				<span class="floater floater--lg floater--tr accent-1 animate-float" aria-hidden="true"></span>
				<span class="floater floater--diamond floater--bl accent-5 animate-float-reverse" aria-hidden="true"></span>
				<div class="gb-container">
					<TrustCenterCTA trustHref="/security/#compliance" dpaHref="mailto:security@grobase.dev?subject=DPA%20request" reportHref="mailto:security@grobase.dev?subject=Vulnerability%20report" />
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
