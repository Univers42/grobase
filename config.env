# ─────────────────────────────────────────────────────────────────────────────
# config.env — NON-SECRET configuration (COMMITTED · safe to edit · no API keys)
#
# This is the GLOBAL baseline everyone shares. It holds hosts, URLs, names,
# feature toggles and tuning — nothing secret. Generated secrets live in
# .env.secrets (gitignored); external API creds + per-developer overrides live
# in .env.local (gitignored). `make env` assembles all three into .env in that
# order, so .env.local wins over .env.secrets wins over config.env.
#
# Host PORTS are NOT here — scripts/ops/resolve-ports.sh owns them and
# auto-increments any that are busy at `make up` time.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database identity (the PASSWORD is in .env.secrets) ──
POSTGRES_USER=postgres
POSTGRES_DB=postgres
PGRST_DB_SCHEMA=public
PGRST_DB_ANON_ROLE=anon

# ── MongoDB (root PASSWORD is in .env.secrets) ──
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=mini_baas
MONGO_INITDB_ROOT_USERNAME=mongo
ANALYTICS_MONGO_DB=mini_baas_analytics
AI_MONGO_DB=mini_baas_ai

# ── Public URLs / CORS origins (change for your host) ──
API_EXTERNAL_URL=https://localhost:8443/auth/v1
GOTRUE_SITE_URL=https://localhost:5173
GOTRUE_URI_ALLOW_LIST=https://localhost:5173/**
# Dev/local: signup returns a session immediately (no real email confirmation).
# Production overlays should set this false so email verification is enforced.
GOTRUE_MAILER_AUTOCONFIRM=true
# Dev/local: trust raw identity headers (x-user-id etc.) so local clients/tests
# work without minting a signed envelope. Production MUST be strict (the prod
# overlay sets IDENTITY_HEADER_MODE=strict); strict rejects raw identity headers.
IDENTITY_HEADER_MODE=compat
KONG_CORS_ORIGIN_APP=https://localhost:3000
KONG_CORS_ORIGIN_PLAYGROUND=https://localhost:3100
KONG_CORS_ORIGIN_STUDIO=https://localhost:3001
KONG_CORS_ORIGIN_FRONTEND=https://localhost:5173
STUDIO_PG_META_URL=http://host.docker.internal:8080
SUPABASE_URL=https://localhost:8443
SUPABASE_PUBLIC_URL=https://localhost:8443
FRONTEND_URL=http://localhost:5173

# ── Internal service URLs (container network) ──
# The adapter-registry is the Go service `adapter-registry-go` on :3021 (the TS
# `adapter-registry` on :3020 was retired post-parity). A stale value here makes
# query-router fail mount resolution with `getaddrinfo EAI_AGAIN adapter-registry`.
ADAPTER_REGISTRY_URL=http://adapter-registry-go:3021
QUERY_ROUTER_URL=http://query-router:4001
MINIO_ROOT_USER=minioadmin

# ── SMTP (local dev = mailpit; real-provider USER/PASS go in .env.local) ──
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
EMAIL_FROM=noreply@mini-baas.local

# ── OAuth toggles (the CLIENT_ID/SECRET pairs go in .env.local) ──
GOOGLE_OAUTH_ENABLED=false
GITHUB_OAUTH_ENABLED=false
FORTYTWO_OAUTH_ENABLED=false

# ── Vault (empty = disabled; services fall back to env vars) ──
VAULT_ADDR=
VAULT_PORT=8200

# ── WAF / SPA host ports (defaults; resolve-ports.sh may bump if busy) ──
WAF_HTTP_PORT=8880
WAF_HTTPS_PORT=8443
FRONTEND_PORT=5173

# ── AI service (LLM_API_KEY goes in .env.local) ──
LLM_API_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
AI_CONVERSATION_TTL_HOURS=24

# ── Optional integration creds: declared EMPTY here so the vars are always
#    defined; put REAL values in .env.local (gitignored), which overrides these.
#    No secret ever belongs in this committed file — only the empty declaration. ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=
SMTP_USER=
SMTP_PASS=
LLM_API_KEY=
GDPR_DELETION_WEBHOOK_URL=
GDPR_EXPORT_WEBHOOK_URL=

# ── Tuning ──
RUST_LOG=info
LOG_LEVEL=info
LOG_BUFFER_SIZE=1000
ANALYTICS_RETENTION_DAYS=90
NEWSLETTER_BATCH_SIZE=5
SESSION_TTL_DAYS=7
